---
import type { SigilKind } from '@/lib/grimoire/sigils';

interface Props {
  kind: SigilKind;
  class?: string;
}

const { kind, class: className } = Astro.props;
---

<svg
  class:list={['grimoire-sigil', className]}
  viewBox="0 0 48 48"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  {
    kind === 'hearth' && (
      <>
        <path
          d="M24 38c-6-8-10-14-10-20a10 10 0 0 1 20 0c0 6-4 12-10 20Z"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linejoin="round"
        />
        <path
          d="M20 22c1.5 2 3 3 4 5 1-2 2.5-3 4-5M24 14v4"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
        />
        <rect x="8" y="34" width="32" height="6" rx="1" stroke="currentColor" stroke-width="1.5" />
      </>
    )
  }

  {
    kind === 'scroll' && (
      <>
        <path
          d="M14 10h16a4 4 0 0 1 4 4v24a4 4 0 0 1-4 4H14a4 4 0 0 1-4-4V14a4 4 0 0 1 4-4Z"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <path d="M18 10V6M30 10V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <path
          d="M16 20h16M16 26h12M16 32h14"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linecap="round"
          opacity="0.7"
        />
      </>
    )
  }

  {
    kind === 'crystal' && (
      <>
        <path
          d="M24 6 36 18v12L24 42 12 30V18L24 6Z"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linejoin="round"
        />
        <path d="M12 18h24M24 6v36M12 30l12-12 12 12" stroke="currentColor" stroke-width="1.2" opacity="0.55" />
      </>
    )
  }

  {
    kind === 'portal' && (
      <>
        <circle cx="24" cy="24" r="16" stroke="currentColor" stroke-width="1.5" />
        <circle cx="24" cy="24" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.6" />
        <path
          d="M24 8v8M24 32v8M8 24h8M32 24h8"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linecap="round"
        />
        <circle cx="24" cy="24" r="2" fill="currentColor" />
      </>
    )
  }

  {
    kind === 'candle' && (
      <>
        <rect x="20" y="22" width="8" height="18" rx="1" stroke="currentColor" stroke-width="1.5" />
        <path
          d="M24 22c-2-3-4-5-2-8 1.5-2 3.5-1 4 1.5 1.5-2.5 0-5-2-6.5"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path d="M22 14c1 1 2 1 4 0" stroke="currentColor" stroke-width="1.2" opacity="0.6" />
      </>
    )
  }

  {
    kind === 'moon' && (
      <>
        <path
          d="M30 10a14 14 0 1 0 4 28 11 11 0 0 1-4-28Z"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linejoin="round"
        />
        <circle cx="34" cy="14" r="1" fill="currentColor" opacity="0.5" />
        <circle cx="38" cy="22" r="0.75" fill="currentColor" opacity="0.35" />
      </>
    )
  }

  {
    kind === 'rune' && (
      <>
        <rect x="10" y="10" width="28" height="28" rx="2" stroke="currentColor" stroke-width="1.5" />
        <path
          d="M16 16h16M16 24h10M16 32h14"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
        />
        <path d="M32 24l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </>
    )
  }
</svg>
