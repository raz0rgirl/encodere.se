---
interface Props {
  roomCount: number;
}

const { roomCount } = Astro.props;
---

<div class="grimoire-atrium">
  <svg class="grimoire-atrium__house" viewBox="0 0 960 420" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    <defs>
      <linearGradient id="grimoire-roof" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="var(--encodere-violet)" stop-opacity="0.12" />
        <stop offset="100%" stop-color="var(--encodere-violet)" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="grimoire-floor" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="var(--encodere-cyan)" stop-opacity="0" />
        <stop offset="50%" stop-color="var(--encodere-cyan)" stop-opacity="0.08" />
        <stop offset="100%" stop-color="var(--encodere-cyan)" stop-opacity="0" />
      </linearGradient>
    </defs>

    <!-- roof -->
    <path
      d="M80 120 480 20 880 120"
      fill="url(#grimoire-roof)"
      stroke="var(--encodere-rule)"
      stroke-width="1"
      stroke-linejoin="round"
    />

    <!-- walls -->
    <rect
      x="80"
      y="120"
      width="800"
      height="260"
      fill="none"
      stroke="var(--encodere-rule)"
      stroke-width="1"
    />

    <!-- floor boards -->
    <line x1="80" y1="380" x2="880" y2="380" stroke="url(#grimoire-floor)" stroke-width="2" />
    <line x1="120" y1="380" x2="120" y2="120" stroke="var(--encodere-rule)" stroke-width="0.5" opacity="0.4" />
    <line x1="320" y1="380" x2="320" y2="120" stroke="var(--encodere-rule)" stroke-width="0.5" opacity="0.4" />
    <line x1="520" y1="380" x2="520" y2="120" stroke="var(--encodere-rule)" stroke-width="0.5" opacity="0.4" />
    <line x1="720" y1="380" x2="720" y2="120" stroke="var(--encodere-rule)" stroke-width="0.5" opacity="0.4" />

    <!-- chimney -->
    <rect x="700" y="40" width="36" height="90" fill="none" stroke="var(--encodere-rule)" stroke-width="1" />
    <path d="M718 30c4-8 8-8 12 0" stroke="var(--encodere-cyan)" stroke-width="1" opacity="0.35" fill="none" />

    <!-- door arch (center) -->
    <path
      d="M430 380V260a50 50 0 0 1 100 0v120"
      fill="none"
      stroke="var(--encodere-violet)"
      stroke-width="1"
      opacity="0.35"
    />

    <!-- window dots -->
    <circle cx="200" cy="200" r="24" fill="none" stroke="var(--encodere-rule)" stroke-width="0.75" opacity="0.5" />
    <circle cx="760" cy="200" r="24" fill="none" stroke="var(--encodere-rule)" stroke-width="0.75" opacity="0.5" />
    <circle cx="480" cy="180" r="18" fill="none" stroke="var(--encodere-cyan)" stroke-width="0.75" opacity="0.3" />
  </svg>

  <div class="grimoire-atrium__content">
    <div class="grimoire-atrium__welcome">
      <svg class="grimoire-atrium__lantern" viewBox="0 0 32 48" aria-hidden="true">
        <path d="M16 4v6M12 10h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
        <rect x="10" y="10" width="12" height="22" rx="2" stroke="currentColor" stroke-width="1.2" fill="none" />
        <path
          d="M16 32c-3 4-5 8-5 12h10c0-4-2-8-5-12Z"
          stroke="currentColor"
          stroke-width="1.2"
          fill="currentColor"
          fill-opacity="0.08"
        />
        <ellipse cx="16" cy="18" rx="3" ry="5" fill="currentColor" opacity="0.2" />
      </svg>
      <p class="grimoire-atrium__welcome-text">
        {roomCount} {roomCount === 1 ? 'sala acesa' : 'salas acesas'} · passe pelos corredores do grimório
      </p>
    </div>

    <slot />
  </div>
</div>
