---
import SiteLayout from '../../layouts/SiteLayout.astro';
import GlitchTitle from '../../components/ui/GlitchTitle.astro';
import AsciiRule from '../../components/ui/AsciiRule.astro';
import BreachThreatMap from '../../components/micro-saas/BreachThreatMap';
import RiskQuiz from '../../components/micro-saas/RiskQuiz';
import PricingGrid from '../../components/micro-saas/PricingGrid.astro';
import WhatsAppButton from '../../components/micro-saas/WhatsAppButton.astro';
import { buildWhatsAppUrl } from '@/lib/micro-saas/whatsapp';

const title = 'Micro SaaS Seguro — Consultoria de Segurança';
const description =
  'Diagnóstico rápido de risco, preços transparentes e consultoria hands-on para tornar seu micro SaaS seguro.';

const generalWhatsApp = buildWhatsAppUrl(
  'Olá! Quero saber mais sobre consultoria de segurança para micro SaaS no encodere.se.',
);
---

<SiteLayout title={title} description={description} wide>
    <header slot="hero" class="encodere-hero__header ms-hero">
      <div class="encodere-content">
        <p class="encodere-section__eyebrow">consultoria · micro saas</p>
        <GlitchTitle text="micro saas seguro" as="h1" />
        <AsciiRule />
        <p class="ms-hero__lede">
          Seu produto fatura todo mês — mas um breach pode custar <mark>12 meses de MRR</mark> em
          multas, churn e reputação.
        </p>
        <p>
          Consultoria especializada para fundadores de micro SaaS que precisam de segurança real, sem
          enterprise theater.
        </p>
        <div class="encodere-cta__actions" style="margin-top: var(--space-6);">
          <a class="btn btn--primary btn--lg" href="#diagnostico">fazer diagnóstico grátis</a>
          <a class="btn btn--ghost btn--lg" href="#precos">ver preços</a>
        </div>
      </div>
    </header>

    <section class="encodere-section">
      <p class="encodere-section__eyebrow">por que importa</p>
      <h2>micro saas é alvo fácil</h2>
      <div class="ms-stats">
        <div class="ms-stat">
          <span class="ms-stat__value">43%</span>
          <p class="ms-stat__label">
            dos ataques cyber miram pequenas empresas — você compete com times de 2 pessoas contra
            botnets automatizados.
          </p>
        </div>
        <div class="ms-stat">
          <span class="ms-stat__value">R$ 180k</span>
          <p class="ms-stat__label">
            custo médio de um incidente com vazamento de dados para PMEs no Brasil (multa LGPD +
            churn + remediação).
          </p>
        </div>
        <div class="ms-stat">
          <span class="ms-stat__value">72h</span>
          <p class="ms-stat__label">
            é o prazo típico para notificar a ANPD após confirmar vazamento — sem playbook, vira
            pânico.
          </p>
        </div>
      </div>
    </section>

    <section class="encodere-section ms-breach-section" id="mapa-risco">
      <p class="encodere-section__eyebrow">superfície de ataque</p>
      <h2>seu micro saas no radar de quem quer seus dados</h2>
      <p>
        Mapa de exfiltração simulado — cada vetor abaixo aparece em incidentes reais de produtos com
        equipe pequena, deploy rápido e zero revisão de segurança.
      </p>
      <BreachThreatMap client:visible />
    </section>

    <section class="encodere-section">
      <p class="encodere-section__eyebrow">como funciona</p>
      <h2>do diagnóstico ao hardening</h2>
      <div class="ms-steps">
        <div class="ms-step">
          <span class="ms-step__num">01</span>
          <div>
            <h3>trivia de 2 minutos</h3>
            <p>
              Responda 7 perguntas sobre usuários, dados e controles. Receba uma estimativa de
              exposição financeira em reais.
            </p>
          </div>
        </div>
        <div class="ms-step">
          <span class="ms-step__num">02</span>
          <div>
            <h3>pacote sob medida</h3>
            <p>
              Com base no seu score, sugerimos Diagnóstico Express, Hardening Sprint ou Guardião
              Mensal — sem upsell genérico.
            </p>
          </div>
        </div>
        <div class="ms-step">
          <span class="ms-step__num">03</span>
          <div>
            <h3>WhatsApp → call → entrega</h3>
            <p>
              Envie seu diagnóstico pelo WhatsApp. Agendamos uma call e começamos a fechar os
              buracos críticos na sua stack.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="encodere-section" id="diagnostico">
      <p class="encodere-section__eyebrow">diagnóstico rápido</p>
      <h2>quanto um breach pode te custar?</h2>
      <p>
        Trivia educativa — leva cerca de 2 minutos. No final, você recebe uma estimativa em BRL e um
        link para falar comigo no WhatsApp com tudo preenchido.
      </p>
      <RiskQuiz client:visible />
    </section>

    <PricingGrid />

    <section class="encodere-section ms-cta-final">
      <p class="encodere-section__eyebrow">próximo passo</p>
      <h2>shippar rápido não precisa significar exposto</h2>
      <p>
        Se você tem MRR recorrente e dados de usuários, segurança não é luxo — é seguro de negócio.
        Vamos conversar.
      </p>
      <div class="ms-cta-final__actions">
        <WhatsAppButton href={generalWhatsApp} variant="primary" size="lg">
          falar no WhatsApp
        </WhatsAppButton>
        <a class="btn btn--ghost btn--lg" href="#diagnostico">refazer diagnóstico</a>
      </div>
    </section>
</SiteLayout>
